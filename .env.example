# Agent X — environment template. Copy to `.env.local` and fill in.
# `.env.local` is gitignored. Never commit real keys.

# --- Required ---

# Anthropic API key for the default Claude Opus 4.6 model.
ANTHROPIC_API_KEY=

# --- Optional ---

# Local home directory for Agent X state (DB, Chromium profile, logs).
# Defaults to `~/.agent-x` if unset.
# AGENT_X_HOME=

# Dev server port. Defaults to 3000.
# AGENT_X_PORT=3000

# Override the default model. Must be a model id the chosen provider supports.
# Available Anthropic ids include: claude-opus-4-6, claude-opus-4-7,
# claude-sonnet-4-6, claude-sonnet-4-5, claude-haiku-4-5.
# DEFAULT_MODEL=claude-opus-4-6

# --- Tool keys (only required when the corresponding tool is invoked) ---
# Governed public-web fetch. Defaults to `*` for local sandbox use while still
# blocking localhost/private IP ranges. Comma-separated hostnames or wildcards:
#   AGENT_X_WEB_ALLOWLIST=kernel.sh,*.kernel.sh,docs.anthropic.com
# AGENT_X_WEB_ALLOWLIST=*

# Kernel browser middleware (for the next browser-backed web tool slice).
# Get this from the Kernel dashboard. Required only when Kernel browser tools run.
# KERNEL_API_KEY=
# AGENT_BROWSER_PROVIDER=kernel
# KERNEL_PROFILE_NAME=agent-x-local

# Web search provider keys are still provider-selection work; web.fetch is live.

# WEB_SEARCH_PROVIDER=tavily          # tavily | exa | brave | none
# TAVILY_API_KEY=
# EXA_API_KEY=
# BRAVE_SEARCH_API_KEY=
